          data: { action: 'click->modal#open', modal_id_param: "turbo-modal", turbo_frame: :modal },
          class: "block bg-blue text-white rounded-full px-8 py-3 font-medium" %>  
      <% else %>
        <%= link_to "Post a ride", 
          new_session_path(return_to: new_trip_path), 
