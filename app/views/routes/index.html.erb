<section class="bg-sheet">
  <div class="mt-8 py-3 pb-6 flex items-center justify-between border-b border-gray-200">
    <h1 class="text-3xl font-medium flex items-center gap-x-2">
      <p class="block"><%= @from_place.name %></p>
      <%= inline_svg_tag "long_arrow.svg", class: "w-6 h-8 stroke-3 stroke-black-200" %>
      <p class="block"><%= @to_place.name %></p>
      <p class="text-base p-1 text-black-200 rounded-sm ml-2 mt-2 block font-bold"><%= @route.distance_km %> km</p>
    </h1>
  </div>

  <%= inline_svg_tag "highway_car.svg", class: "hidden car-sliding w-24 mt-4 block" %>

  <div class="">
    <div class="flex items-start gap-x-8">

      <%# Trip list — left column %>
      <div class="w-3/5 mx-2 pt-6">


        <div class="mt-4 flex items-center justify-between mb-12">
          <div class="flex items-center gap-x-6 text-[17px] text-[#3C3C43]/60">
            <h2 class="bg-[#3C3C43]/10 pl-3 pr-6 py-2 rounded-md flex items-center gap-x-2">
              <div class="flex items-center justify-center w-7 h-7 bg-blue rounded-md">
                <%= inline_svg_tag "calendar.svg", class: "stroke-white stroke-[1.8] fill-blue w-4.5 h-4.5"%>
              </div>
              <span class="block">Today</span>
            </h2>
            <h2 class="text-[#3C3C43]/40">Tomorrow</h2>
            <h2 class="text-[#3C3C43]/40">Wed 5 Mar</h2>
            <h2 class="text-[#3C3C43]/40">Thurs 6 Mar</h2>
            <h2 class="text-[#3C3C43]/40">Fri 7 Mar</h2>
            <h2 class="text-[#3C3C43]/40">Sat 9 Mar</h2>
            <h2 class="text-[#3C3C43]/40">Sun 10 Mar</h2>
          </div>
        </div>

        <div class="flex flex-col gap-y-10 mt-6">

          <%# Card 1 — Rideshare %>
         
          <div class="  py-3 border border-zinc-200/60 rounded-2xl cursor-pointer">
            <div class="flex items-start justify-between border-b border-zinc-200/60 pt-1 pb-4 px-6">
              <div class="flex items-center gap-x-2 w-1/3">
                <div class="h-11 w-11 border-[1.5px] border-blue rounded-full flex items-center justify-center">
                  <img class="mx-auto block object-cover h-10 w-10 rounded-full bg-gray-300 opacity-90" src="https://img.a.transfermarkt.technology/portrait/big/632349-1758704191.jpg?lm=1">
                </div>
                <div class="">
                  <span class="block mt-1 font-bold text-[20px] text-black-200">Farai Jones</span>
                  <span class="block -mt-1 text-[13px] text-gray-neutral">2 trips driven</span>
                </div>
              </div>
              
              <div class="flex items-center gap-x-2 w-2/3 text-gray-neutral">
                <div class="flex flex-col ml-auto">
                  <div class="flex items-center gap-x-2">
                    <p class="font-bold text-[14px] -mt-0.5">08:00</p>
                    <div class="flex items-center">
                      <div class="itinerary-line"></div>
                      <span class="mx-2 text-black-700">5h40</span>
                      <%= inline_svg_tag "sun.svg", class: "w-4 h-4 stroke-4 block mx-auto mr-2" %>
                      <div class="itinerary-line"></div>
                    </div>
                  </div>
                  <div class="-mt-1.5">
                    <span class="text-[15px] font-medium">Harare</span>
                  </div>
                </div>
                <div class="-mt-0.5">
                  <span class="font-bold text-[14px] block">13:40</span>
                  <span class="text-[15px] font-medium block -mt-1">Bulawayo</span>
                </div>
                <h2 class="font-bold text-3xl w-12 ml-auto text-black-200">$18</h2>
              </div>
            </div>

            <div class="px-6 pt-5 pb-2 flex items-center gap-x-8 text-[15px] text-gray-neutral">
              <div class="flex items-center gap-x-2">
                <%= inline_svg_tag "car_ultra_compact.svg", class: "w-5 h-5 stroke-2 stroke-gray-neutral block" %>
                <span class="">Honda Fit</span>
              </div>
              <div class="flex items-center gap-x-1">
                <%= inline_svg_tag "luggage.svg", class: "w-6 h-5 stroke-gray-neutral stroke-[1.6] fill-none"%>
                <span class="block">Small luggage allowed</span>
              </div>
              <p class="ml-auto text-[18px]">3 seats left</p>
            </div>
          </div>



         <div class=" bg-beige-pale py-3 border border-zinc-200/60 rounded-2xl cursor-pointer">
            <div class="flex items-start justify-between border-b border-zinc-200/60 pt-1 pb-4 px-6">
              <div class="flex items-center gap-x-2 w-1/3">
                <div class="h-11 w-11 border-[1.5px] border-blue rounded-full flex items-center justify-center">
                  <img class="mx-auto block object-cover h-10 w-10 rounded-full bg-gray-300" src="https://media.istockphoto.com/id/174871013/photo/portrait-of-a-mature-woman-with-pleasant-expression.jpg?s=612x612&w=0&k=20&c=iI3uZNUd9b3PCYzg7e7Nbs3dz_dRh_n5Javry39jI9E=">
                </div>
                <div class="">
                  <span class="block mt-1 font-bold text-[20px] text-black-200">Kayla Makoni</span>
                  <span class="block -mt-1 text-[13px] text-gray-neutral">1 trip driven</span>
                </div>
              </div>
              
              <div class="flex items-center gap-x-2 w-2/3 text-gray-neutral">
                <div class="flex flex-col ml-auto">
                  <div class="flex items-center gap-x-2">
                    <p class="font-bold text-[14px] -mt-0.5">10:00</p>
                    <div class="flex items-center">
                      <div class="itinerary-line"></div>
                      <span class="mx-2 text-black-700">5h40</span>
                      <%= inline_svg_tag "sun.svg", class: "w-4 h-4 stroke-4 block mx-auto mr-2" %>
                      <div class="itinerary-line"></div>
                    </div>
                  </div>
                  <div class="-mt-1.5">
                    <span class="text-[15px] font-medium">Harare</span>
                  </div>
                </div>
                <div class="-mt-0.5">
                  <span class="font-bold text-[14px] block">15:40</span>
                  <span class="text-[15px] font-medium block -mt-1">Bulawayo</span>
                </div>
                <h2 class="font-bold text-3xl w-12 ml-auto text-black">$25</h2>
              </div>
            </div>

            <div class="px-6 pt-5 pb-2 flex items-center gap-x-8 text-[15px] text-gray-neutral">
              <div class="flex items-center gap-x-2">
                <%= inline_svg_tag "car_ultra_compact.svg", class: "w-5 h-5 stroke-2 stroke-gray-neutral block" %>
                <span class="">Toyota Corolla</span>
              </div>
              <div class="flex items-center gap-x-1">
                <%= inline_svg_tag "butterfly.svg", class: "w-6 h-8 fill-blue stroke-[2.4] fill-none"%>
                <span class="block">Women Only</span>
              </div>
              <div class="flex items-center gap-x-1">
                <%= inline_svg_tag "luggage.svg", class: "w-6 h-5 stroke-blue-gray-neutral stroke-[1.6] fill-none"%>
                <span class="block">Small luggage allowed</span>
              </div>
              <p class="ml-auto text-[18px]">1 seat left</p>
            </div>
          </div>
        </div>

         <div class=" mt-12 bg-[#323055] py-3 border border-zinc-200/60 rounded-2xl cursor-pointer">
            <div class="flex items-start justify-between border-b-[1.2px] border-black pt-1 pb-4 px-6">
              <div class="flex items-center gap-x-2 w-1/3">
                <div class="h-11 w-11 border-[1.5px] border-zinc-500 rounded-full flex items-center justify-center">
                  <img class="mx-auto block object-cover h-10 w-10 rounded-full bg-gray-300" src="https://hogg.utexas.edu/wp-content/uploads/2019/07/mia.png">
                </div>
                <div class="">
                  <span class="block mt-1 font-bold text-[20px] text-zinc-300">Sylvia Nyagumbo</span>
                  <span class="block -mt-1 text-[13px] text-zinc-400">12 trips driven</span>
                </div>
              </div>
              
              <div class="flex items-center gap-x-2 w-2/3 text-zinc-400">
                <div class="flex flex-col ml-auto">
                  <div class="flex items-center gap-x-2">
                    <p class="font-bold text-[14px] -mt-0.5">18:00</p>
                    <div class="flex items-center">
                      <div class="itinerary-line itinerary-line-night"></div>
                      <div class="flex items-center  mx-2">
                        <span class="mx-2 text-zinc-400">5h40</span>
                        <%= inline_svg_tag "moon.svg", class: "w-4 stroke-yellow-600 fill-yellow-600" %>
                      </div>
                      <div class="itinerary-line itinerary-line-night"></div>
                    </div>
                  </div>
                  <div class="-mt-1.5">
                    <span class="text-[15px] font-medium">Harare</span>
                  </div>
                </div>
                <div class="-mt-0.5">
                  <span class="font-bold text-[14px] block">23:40</span>
                  <span class="text-[15px] font-medium block -mt-1">Bulawayo</span>
                </div>
                <h2 class="font-bold text-3xl w-12 ml-auto ">$25</h2>
              </div>
            </div>

            <div class="px-6 pt-5 pb-2 flex items-center gap-x-8 text-[15px] text-zinc-400">
              <div class="flex items-center gap-x-2">
                <%= inline_svg_tag "car_ultra_compact.svg", class: "w-5 h-5 stroke-2 stroke-zinc-400 block" %>
                <span class="">Toyota Wish</span>
              </div>
              <div class="flex items-center gap-x-1">
                <%= inline_svg_tag "butterfly_night.svg", class: "fill-blue w-6 h-8 stroke-[2.4] fill-none"%>
                <span class="block">Women Only</span>
              </div>
              <div class="flex items-center gap-x-1">
                <%= inline_svg_tag "luggage.svg", class: "w-6 h-5 stroke-zinc-400 stroke-[1.6] fill-none"%>
                <span class="block">Mid sized luggage allowed</span>
              </div>
              <p class="ml-auto text-[18px]">1 seat left</p>
            </div>
          </div>
      </div>

      <%# Sidebar — right column %>
    <div class="w-2/5 px-12 pt-10 h-screen">
      <div class="border-b border-gray-200 pb-6">
        <h1 class="text-xl font-bold">Sort by</h1>
        <div class="mt-3">
          <label class="form-control">
            <input type="radio" name="sort" value="earliest" checked />
            <span>Earliest departure</span>

            <%= inline_svg_tag "clock.svg", class: "w-5 h-6 stroke-gray-neutral/80 stroke-2 ml-auto" %>
          </label>

          <label class="form-control mt-4">
            <input type="radio" name="sort" value="price" />
            <span>Lowest price</span>

            <%= inline_svg_tag "money.svg", class: "w-5 h-6 stroke-gray-neutral/80 stroke-2 ml-auto" %>
          </label>
        </div>
      </div>
      <div class="my-6 border-b border-gray-200 pb-6">
        <h1 class="text-xl font-bold">Trust and Safety</h1>
        <div class="mt-4">
          <label class="form-control">
            <input type="checkbox" name="sort_earliest" />
            <span>Verified drivers</span>
            <%= inline_svg_tag "shield.svg", class: "w-5 h-6 stroke-gray-neutral/80 stroke-2 ml-auto" %>
          </label>

          <label class="form-control mt-4">
            <input type="checkbox" name="sort_price" />
            <span class="block">Women-only trips</span>
            <%= inline_svg_tag "butterfly.svg", class: "w-5 h-6 stroke-gray-neutral/80 stroke-2 ml-auto" %>
          </label>
        </div>
      </div>
      <div class="my-6 border-b border-gray-200 pb-6">
        <h1 class="text-xl font-bold">Amenities</h1>
        <div class="mt-4">
          <label class="form-control">
            <input type="checkbox" name="sort_earliest" />
            <span>Max 3 people at the backseat</span>
            <%= inline_svg_tag "three_users.svg", class: "w-5 h-6 stroke-gray-neutral/80 stroke-2 ml-auto" %>
          </label>

          <label class="form-control mt-5">
            <input type="checkbox" name="sort_price" />
            <span>Instant booking</span>
            <%= inline_svg_tag "electric.svg", class: "w-5 h-6 stroke-gray-neutral/80 stroke-2 ml-auto" %>
          </label>
        </div>        
      </div>      
    </div>

    </div>
  </div>
</section>
