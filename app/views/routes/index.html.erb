<section class="bg-sheet">
  <div class="mt-8 py-3 pb-6 flex items-center justify-between border-b border-gray-200">
    <h1 class="text-3xl font-extrabold flex items-center gap-x-2">
      <p class="block"><%= @from_place.name %></p>
      <%= inline_svg_tag "long_arrow.svg", class: "w-6 h-8 stroke-3 stroke-black-200" %>
      <p class="block"><%= @to_place.name %></p>
      <p class="text-base p-1 text-black-200 rounded-sm ml-2 mt-2 block font-bold"><%= @route.distance_km %> km</p>
    </h1>
  </div>

  <%= inline_svg_tag "highway_car.svg", class: "car-sliding w-24 -mt-8 block" %>

  <%= form_with url: routes_path, 
              method: :get, 
              data: { controller: "trip-filters", 
              action: "change->trip-filters#submit", turbo_frame: "trips",
              class: "w-2/5 px-12 mt-12 h-screen" } do |form| %>
    <%= form.hidden_field :from, value: params[:from] %>
    <%= form.hidden_field :to, value: params[:to] %>

    <div class="flex items-start gap-x-8">
      <div class="w-3/5 mx-2">
        <div class="my-10 flex items-center gap-x-3">
          <% day_range.each do |day| %>
            <%= form.label :date, value: day, class: "block cursor-pointer" do %>
              <%= form.radio_button :date, day, class: "peer sr-only", checked: day.today? %>
              
              <% if day.today? %>
                <div class="flex items-center gap-x-2 peer-checked:bg-[#3C3C43]/10 p-2 rounded-md">
                  <div class="flex items-center justify-center w-7 h-7 bg-blue rounded-md">
                    <%= inline_svg_tag "calendar.svg", class: "stroke-white stroke-[1.8] fill-blue w-4.5 h-4.5" %>
                  </div>
                  <p class="peer-checked:text-black-300">
                    <%= trip_day_label(day) %>
                  </p>
                </div>
              <% else %>
                <p class="text-[#3C3C43]/40 text-[17px] peer-checked:text-black-300 peer-checked:bg-[#3C3C43]/10 p-2 rounded-md">
                  <%= trip_day_label(day) %>
                </p>
              <% end %>
            <% end %> 
            <% end%>    
        </div>

      <turbo-frame id="trips">
        <%= render "trips/list", trips: @trips %>
        <p class="turbo-loading text-sm text-gray-neutral">Loading trips...</p>
      </turbo-frame>
    </div>

      <%# Sidebar — right column %>

      <div class="w-2/5 px-12">
          <div class="border-b border-gray-200 pt-10 pb-6">
            <h1 class="text-xl font-bold">Sort by</h1>
              <div class="mt-3">
                <label class="form-control mb-3 flex items-center">
                  <%= form.radio_button :sort, "departure_time", checked: params[:sort] == "departure_time", class: "-mt-[1px]!" %>
                  <span>Earliest departure</span>
                  <%= inline_svg_tag "clock.svg", class: "w-5 h-5 block stroke-[1.5] stroke-gray-neutral/80 ml-auto" %>
                </label>

                <label class="form-control">
                  <%= form.radio_button :sort, "price", checked: params[:sort] == "price", class: "-mt-[1px]!" %>
                  <span>Lowest price</span>
                  <%= inline_svg_tag "money.svg", class: "w-5 h-5 block stroke-[1.5] stroke-gray-neutral/80 ml-auto" %>
                </label>
              </div>
            </div>
            <div class="my-6 border-b border-gray-200 pb-6">
              <h1 class="text-xl font-bold">Trust and Safety</h1>
              <div class="mt-4">
                <label class="form-control mb-3">
                  <%= form.check_box :verified_drivers, { checked: params[:verified_drivers], include_hidden: false } %>
                  <span>Verified drivers</span>
                  <%= inline_svg_tag "shield.svg", class: "w-5 h-6 stroke-gray-neutral/80 stroke-2 ml-auto -mt-0.5" %>
                </label>

               <label class="form-control">
                  <%= form.check_box :women_only, { checked: params[:women_only], include_hidden: false } %>
                  <span>Women-only trips</span>
                  <%= inline_svg_tag "butterfly.svg", class: "w-5 h-6 stroke-gray-neutral/80 stroke-2 ml-auto -mt-0.5" %>
                </label>
              </div>
            </div>

            <div class="my-6 border-b border-gray-200 pb-6">
              <h1 class="text-xl font-bold">Amenities</h1>
              <div class="mt-4">

               <label class="form-control mb-3">
                  <%= form.check_box :max_three_at_the_back, { checked: params[:max_three_at_the_back], include_hidden: false } %>
                  <span>Max 3 people at the backseat</span>
                  <%= inline_svg_tag "three_users.svg", class: "w-5 h-6 stroke-gray-neutral/80 stroke-2 ml-auto -mt-0.5" %>
                </label>

               <label class="form-control">
                  <%= form.check_box :instant_booking, { checked: params[:instant_booking], include_hidden: false } %>
                  <span>Instant booking</span>
                  <%= inline_svg_tag "electric.svg", class: "w-5 h-6 stroke-gray-neutral/80 stroke-2 ml-auto -mt-0.5" %>
                </label>
              </div>        
            </div>      
          </div>
       
      </div>

  </div>
   <% end %>
</section>
