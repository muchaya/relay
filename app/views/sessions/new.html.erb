<%= turbo_frame_tag "modal" do %>
  <div class="h-screen flex items-center justify-center">
    <%= form_with url: session_path, data: { turbo_frame: "_top" }, class: "w-1/3 bg-white pt-6 pb-8 px-6 rounded-xl mx-auto" do |form| %>
      <div class="flex items-center justify-between border-b border-gray-300 pb-4 mb-6">
        <div>
          <h2 class="text-4xl font-bold">Welcome back!</h2>
          <h3 class="text-sm text-gray-500 tracking-white mt-2">We've been expecting you</h3>
        </div>
        <%= tag.a data: { action: "click->modal#close", modal_id_param: "turbo-modal" }, class: "cursor-pointer" do %>
          <%= inline_svg_tag "close.svg", class: "stroke-black stroke-[1.5] h-5 w-5 fill-black" %>
        <% end %>
      </div>

      <div id="form-error-container"></div>

      <div class="flex flex-col">
        <div class="relative mt-3.5">
          <%= form.telephone_field :phone_number,
              placeholder: " ",
              required: true,
              class: "text-slate-800 peer border border-gray-400 text-lg px-3 pt-5 pb-3 rounded-sm w-full focus:outline-none focus:border-blue focus:shadow-[0_0_4px_#0057b8,inset_0_0_2px_#0f6fff]" %>
          <label class="absolute left-3 top-3.5 text-gray-400 text-lg transition-all duration-200 pointer-events-none
                        peer-placeholder-shown:top-3.5 peer-placeholder-shown:text-lg peer-placeholder-shown:text-[#4f5b69]
                        peer-focus:top-1 peer-focus:text-xs peer-focus:text-[#4f5b69]
                        peer-[:not(:placeholder-shown)]:top-1 peer-[:not(:placeholder-shown)]:text-xs peer-[:not(:placeholder-shown)]:text-[#4f5b69]">
            <div class="flex items-center gap-x-1">
              Phone number <span class="ml-2 text-[13px] text-slate-600 tracking-wider">eg. 0781 222 000</span> <%= inline_svg_tag "asterisk.svg", class: "stroke-2 w-2 h-2 -mt-1" %>
            </div>
          </label>
        </div>  

        <div data-controller="password-toggle" class="relative mt-3.5">
          <%= form.password_field :password,
              data: { password_toggle_target: :input, action: "input->password-toggle#input" },
              required: true,
              placeholder: " ",
              class: "peer border border-gray-400 text-lg px-3 pt-5 pb-2 pr-10 rounded-sm w-full focus:outline-none focus:border-blue focus:shadow-[0_0_4px_#0057b8,inset_0_0_2px_#0f6fff]" %>
          <label class="absolute left-3 top-3.5 text-gray-400 text-lg transition-all duration-200 pointer-events-none
                        peer-placeholder-shown:top-3.5 peer-placeholder-shown:text-lg peer-placeholder-shown:text-[#4f5b69]
                        peer-focus:top-1 peer-focus:text-xs peer-focus:text-[#4f5b69]
                        peer-[:not(:placeholder-shown)]:top-1 peer-[:not(:placeholder-shown)]:text-xs peer-[:not(:placeholder-shown)]:text-[#4f5b69]">
            <div class="flex items-center gap-x-1">
              Password <%= inline_svg_tag "asterisk.svg", class: "fill-[#c01f2b] stroke-2 w-2 h-2 -mt-1" %>
            </div>
          </label>
          <div data-password-toggle-target="block" class="hidden absolute right-3 top-1/2 -translate-y-1/2">
            <%= inline_svg_tag "show_password.svg", data: { action: "click->password-toggle#toggle", password_toggle_target: "show" }, class: "w-5 h-5 fill-slate-800 cursor-pointer" %>
            <%= inline_svg_tag "hide_password.svg", data: { action: "click->password-toggle#toggle", password_toggle_target: "hide" }, class: "hidden w-5 h-5 cursor-pointer" %>
          </div>
        </div>

        <div class="flex items-center gap-x-4 justify-between border-b border-gray-300 pb-8 mt-12">
          <%= form.submit "Log in", 
            class: "w-2/3 block bg-blue text-white text-lg font-medium py-4 rounded-full cursor-pointer transition-colors duration-200" %>

          <%= link_to "Forgot password?", new_password_path, class: "w-1/3 block text-lg font-medium decoration underline underline-offset-6" %>
        </div>
        
        <%= link_to "Don't have an account? Join now", new_registration_path(return_to: params[:return_to]), data: { action: 'click->modal#open', modal_id_param: "turbo-modal", turbo_frame: :modal }, class: "w-fit mt-3 text-lg font-medium block mx-auto" %>
      </div>
    <% end %>
  <% end %>
  </div>
