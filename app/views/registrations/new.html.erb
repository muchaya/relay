<%= turbo_frame_tag "modal" do %>
  <div class="h-screen flex items-center justify-center">
    <%= form_with model: User.new, url: registration_path, class: "w-1/3 bg-white pt-6 pb-8 px-6 rounded-xl mx-auto" do |form| %>
      <div class="flex items-center justify-between border-b border-gray-300 pb-4 mb-6">
        <div>
          <h2 class="text-4xl font-bold">Join Relay</h2>
          <h3 class="text-sm text-gray-500 tracking-white mt-2">This is the start of something good.</h3>
        </div>
        <%= tag.a data: { action: "click->modal#close", modal_id_param: "turbo-modal" }, class: "cursor-pointer" do %>
          <%= inline_svg_tag "close.svg", class: "stroke-black stroke-[1.5] h-5 w-5 fill-black" %>
        <% end %>
      </div>

      <div class="flex flex-col mt-8">
        <div class="gap-x-4">
          <div class="relative">
            <%= form.text_field :fullname,
                required: true,
                placeholder: " ",
                class: "text-slate-800 peer border border-gray-400 text-lg px-3 pt-5 pb-3 rounded-sm w-full focus:outline-none focus:border-blue focus:shadow-[0_0_4px_#0057b8,inset_0_0_2px_#0f6fff]" %>
            <label class="absolute left-3 top-3.5 text-gray-400 text-lg transition-all duration-200 pointer-events-none
                          peer-placeholder-shown:top-3.5 peer-placeholder-shown:text-lg peer-placeholder-shown:text-[#4f5b69]
                          peer-focus:top-1 peer-focus:text-xs peer-focus:text-[#4f5b69]
                          peer-[:not(:placeholder-shown)]:top-1 peer-[:not(:placeholder-shown)]:text-xs peer-[:not(:placeholder-shown)]:text-[#4f5b69]">
              <div class="flex items-center gap-x-1">
                Full name <%= inline_svg_tag "asterisk.svg", class: "fill-[#c01f2b] stroke-2 w-2 h-2 -mt-1" %>
              </div>
            </label>
          </div>    

          <div class="relative mt-3.5">
            <%= form.telephone_field :phone_number,
                required: true,
                placeholder: " ",
                class: "text-slate-800 peer border border-gray-400 text-lg px-3 pt-5 pb-3 rounded-sm w-full focus:outline-none focus:border-blue focus:shadow-[0_0_4px_#0057b8,inset_0_0_2px_#0f6fff]" %>
            <label class="absolute left-3 top-3.5 text-gray-400 text-lg transition-all duration-200 pointer-events-none
                          peer-placeholder-shown:top-3.5 peer-placeholder-shown:text-lg peer-placeholder-shown:text-[#4f5b69]
                          peer-focus:top-1 peer-focus:text-xs peer-focus:text-[#4f5b69]
                          peer-[:not(:placeholder-shown)]:top-1 peer-[:not(:placeholder-shown)]:text-xs peer-[:not(:placeholder-shown)]:text-[#4f5b69]">
              <div class="flex items-center gap-x-1">
                Phone number <span class="ml-2 text-[13px] text-slate-600 tracking-wider">eg. 0772 111 222</span> <%= inline_svg_tag "asterisk.svg", class: "fill-[  ] stroke-2 w-2 h-2 -mt-1" %>
              </div>
            </label>
          </div>  
        </div>

        <div class="mt-3.5">
          <div class="relative">
            <%= form.email_field :email_address,
                required: true,
                placeholder: " ",
                class: "text-slate-800 peer border border-gray-400 text-lg px-3 pt-5 pb-3 rounded-sm w-full focus:outline-none focus:border-blue focus:shadow-[0_0_4px_#0057b8,inset_0_0_2px_#0f6fff]" %>
            <label class="absolute left-3 top-3.5 text-gray-400 text-lg transition-all duration-200 pointer-events-none
                          peer-placeholder-shown:top-3.5 peer-placeholder-shown:text-lg peer-placeholder-shown:text-[#4f5b69]
                          peer-focus:top-1 peer-focus:text-xs peer-focus:text-[#4f5b69]
                          peer-[:not(:placeholder-shown)]:top-1 peer-[:not(:placeholder-shown)]:text-xs peer-[:not(:placeholder-shown)]:text-[#4f5b69]">
              <div class="flex items-center gap-x-1">
                Email address <%= inline_svg_tag "asterisk.svg", class: "fill-[#c01f2b] stroke-2 w-2 h-2 -mt-1" %>
              </div>
              
            </label>
          </div>

        <div data-controller="password-toggle" class="relative mt-3.5">
          <%= form.password_field :password,
              required: true,
              data: { password_toggle_target: :input, action: "input->password-toggle#input" },
              placeholder: " ",
              class: "peer border border-gray-400 text-lg px-3 pt-5 pb-2 pr-10 rounded-sm w-full focus:outline-none focus:border-blue focus:shadow-[0_0_4px_#0057b8,inset_0_0_2px_#0f6fff]" %>
          <label class="absolute left-3 top-3.5 text-gray-400 text-lg transition-all duration-200 pointer-events-none
                        peer-placeholder-shown:top-3.5 peer-placeholder-shown:text-lg peer-placeholder-shown:text-[#4f5b69]
                        peer-focus:top-1 peer-focus:text-xs peer-focus:text-[#4f5b69]
                        peer-[:not(:placeholder-shown)]:top-1 peer-[:not(:placeholder-shown)]:text-xs peer-[:not(:placeholder-shown)]:text-[#4f5b69]">
            <div class="flex items-center gap-x-1">
              Password <%= inline_svg_tag "asterisk.svg", class: "fill-[#c01f2b] stroke-2 w-2 h-2 -mt-1" %>
            </div>
          </label>
          <div data-password-toggle-target="block" class="hidden absolute right-3 top-1/2 -translate-y-1/2">
            <%= inline_svg_tag "show_password.svg", data: { action: "click->password-toggle#toggle", password_toggle_target: "show" }, class: "w-5 h-5 fill-slate-800 cursor-pointer" %>
            <%= inline_svg_tag "hide_password.svg", data: { action: "click->password-toggle#toggle", password_toggle_target: "hide" }, class: "hidden w-5 h-5 cursor-pointer" %>
          </div>
        </div>

        <label class="form-control mt-8 mb-6">
          <%= form.check_box :terms_accepted, { checked: true, include_hidden: false } %>
          <span class="text-[14px] text-slate-800 tracking-wide">I certify that I’m at least 16 years old at the time of sign up and agree to the <span class="decoration underline underline-offset-4">Relay Terms of Service</span></span>
        </label>

        <label class="form-control mb-6">
          <%= form.check_box :privacy_policy_accepted, { checked: true, include_hidden: false } %>
          <span class="text-[14px] text-slate-800 tracking-wide">I agree to receive my authentication code via WhatsApp to the phone number provided or optionally to the email provided. <span class="decoration underline underline-offset-4"> View our Privacy Policy</span>
        </label>

        <div class="border-b border-gray-300 pb-8">
          <%= form.submit "Create your Relay account", 
            class: "w-full bg-blue text-white text-lg font-medium py-4 rounded-full cursor-pointer transition-colors duration-200" %>
        </div>
        
        <%= link_to "Already have an account? Login", new_password_path, class: "w-fit mt-3 text-lg font-medium block mx-auto" %>
      </div>
    <% end %>
  <% end %>
  </div>
