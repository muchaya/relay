<section data-controller="popover location-filters" 
         data-action="click@document->popover#outsideClick location-filters:place-selected->popover#closeAllPopovers"
         data-location-filters-routes-graph-value="<%= @routes_graph %>" 
        class="mt-24">

<div class="">
  <%= form_with url: routes_path, method: :get, class: "" do |form| %>
    <%= form.hidden_field :date, value: Date.today %>

  <section class="">
    <div class="flex items-center w-full">
      <div class="w-2/3">
        <div class="flex flex-col gap-y-1 mt-12 font-extrabold text-[64px] tracking-tight mb-6">
          <h1>A better way to</h1>
          <h1 class="-mt-7">hitchhike.</h1>
        </div>

        <div class="mt-8 mb-12 w-3/5 text-black-700 leading-4 tracking-wide">
          <p class="text-xl">Meet real people travelling the same long-distance journey. Relay is simple ridesharing, made with love for hitchhikers.</p>
        </div>
      </div>
      <div class="w-fit -mt-24 -ml-48">

<svg width="520" height="400" viewBox="0 0 420 300" xmlns="http://www.w3.org/2000/svg">

<defs>
  <linearGradient id="routeGradient" x1="0%" y1="0%" x2="100%" y2="0%">
    <stop offset="0%" stop-color="#CBD5E1"/>
    <stop offset="100%" stop-color="#94A3B8"/>
  </linearGradient>
</defs>

<!-- Route -->
<path id="routePath"
  d="M40 240 C140 120 160 260 260 160 C310 120 350 140 380 70"
  fill="none"
  stroke="url(#routeGradient)"
  stroke-width="5"
  stroke-linecap="round"
  stroke-dasharray="10 10"/>

<!-- Moving travel dot -->
<circle r="4" fill="#1E73D8">
  <animateMotion dur="120s" repeatCount="indefinite">
    <mpath href="#routePath"/>
  </animateMotion>
</circle>

<!-- Pin 1 -->
<g transform="translate(40,240)">
  <path d="M0 -16 C9 -16 16 -9 16 0 C16 10 0 22 0 22 C0 22 -16 10 -16 0 C-16 -9 -9 -16 0 -16 Z"
    fill="white" stroke="#1E73D8" stroke-width="4">
    <animate attributeName="stroke" dur="120s" repeatCount="indefinite"
      calcMode="discrete"
      keyTimes="0;0.06;0.93;1"
      values="#A78BA0;#1E73D8;#1E73D8;#A78BA0"/>
  </path>
  <circle cx="0" cy="-1" r="4" fill="#1E73D8">
    <animate attributeName="fill" dur="120s" repeatCount="indefinite"
      calcMode="discrete"
      keyTimes="0;0.06;0.93;1"
      values="#A78BA0;#1E73D8;#1E73D8;#A78BA0"/>
  </circle>
</g>

<!-- Pin 2 -->
<g transform="translate(260,160)">
  <path d="M0 -16 C9 -16 16 -9 16 0 C16 10 0 22 0 22 C0 22 -16 10 -16 0 C-16 -9 -9 -16 0 -16 Z"
    fill="white" stroke="#1E73D8" stroke-width="4">
    <animate attributeName="stroke" dur="120s" repeatCount="indefinite"
      calcMode="discrete"
      keyTimes="0;0.59;0.68;1"
      values="#1E73D8;#A78BA0;#1E73D8;#1E73D8"/>
  </path>
  <circle cx="0" cy="-1" r="4" fill="#1E73D8">
    <animate attributeName="fill" dur="120s" repeatCount="indefinite"
      calcMode="discrete"
      keyTimes="0;0.59;0.68;1"
      values="#1E73D8;#A78BA0;#1E73D8;#1E73D8"/>
  </circle>
</g>

<!-- Pin 3 -->
<g transform="translate(380,70)">
  <path d="M0 -16 C9 -16 16 -9 16 0 C16 10 0 22 0 22 C0 22 -16 10 -16 0 C-16 -9 -9 -16 0 -16 Z"
    fill="white" stroke="#1E73D8" stroke-width="4">
    <animate attributeName="stroke" dur="120s" repeatCount="indefinite"
      calcMode="discrete"
      keyTimes="0;0.93;1"
      values="#1E73D8;#A78BA0;#A78BA0"/>
  </path>
  <circle cx="0" cy="-1" r="4" fill="#1E73D8">
    <animate attributeName="fill" dur="120s" repeatCount="indefinite"
      calcMode="discrete"
      keyTimes="0;0.93;1"
      values="#1E73D8;#A78BA0;#A78BA0"/>
  </circle>
</g>

<!-- Sparkle 1 -->
<g>
  <path d="M170 48 C186 40 202 52 198 72 
           C194 88 176 96 160 88 
           C144 80 144 60 160 48 Z"
        fill="#1E73D8" opacity="0.07"/>
  <animateTransform attributeName="transform"
    type="scale"
    values="1;1.06;1"
    dur="28s"
    repeatCount="indefinite"
    additive="sum"/>
</g>

<!-- Sparkle 2 -->
<g>
  <path d="M320 210 C334 200 352 210 350 228 
           C348 246 332 256 316 250 
           C300 244 302 222 320 210 Z"
        fill="#1E73D8" opacity="0.06"/>
  <animateTransform attributeName="transform"
    type="scale"
    values="1;1.05;1"
    dur="32s"
    repeatCount="indefinite"
    additive="sum"/>
</g>

<!-- Sparkle 3 -->
<g>
  <path d="M90 132 C106 120 124 130 122 150 
           C120 168 104 178 88 170 
           C72 162 74 142 90 132 Z"
        fill="#1E73D8" opacity="0.05"/>
  <animateTransform attributeName="transform"
    type="scale"
    values="1;1.07;1"
    dur="36s"
    repeatCount="indefinite"
    additive="sum"/>
</g>

<!-- Sparkle 4 -->
<g>
  <path d="M340 88 C356 76 376 84 374 106 
           C372 126 356 138 338 132 
           C320 126 322 102 340 88 Z"
        fill="#1E73D8" opacity="0.06"/>
  <animateTransform attributeName="transform"
    type="scale"
    values="1;1.05;1"
    dur="30s"
    repeatCount="indefinite"
    additive="sum"/>
</g>

</svg>

      </div>
    </div>



    <div class="flex items-center">
      <div class="flex items-center w-full bg-sheet border border-gray-300 rounded-full py-1">
        <div data-popover-id-param="leaving-from-popover" data-action="click->popover#open" data-popover-offset-param="0" class="w-2/7 floating-input-container border-r border-gray-300">
          <%= inline_svg_tag "location_v2.svg", class: "ml-4.5 w-5 stroke-1.5 stroke-black-300" %>
          <div class="floating-input-wrapper ">
            <input type="text" data-location-filters-target="leavingFromInput" data-action="focus->location-filters#leavingFromFocus input->location-filters#searchFrom" name="from" class="floating-input" placeholder=" " />
            <label class="floating-label">Leaving from</label>
          </div>
        </div>

        <div data-popover-id-param="going-to-popover" data-action="click->popover#open" data-popover-offset-param="8" class="w-2/7 floating-input-container border-r border-gray-300">
          <%= inline_svg_tag "location_v2.svg", class: "ml-4.5 w-5 stroke-1.5 stroke-black-300" %>
          <div class="floating-input-wrapper">
            <input type="text" data-location-filters-target="goingToInput" data-action="focus->location-filters#goingToFocus input->location-filters#searchTo" name="to" class="floating-input" placeholder=" " />
            <label class="floating-label">Going to</label>
          </div>
        </div>
        <div class="w-2/7 py-5 ">
          <div class="w-fit mx-auto flex items-center gap-x-4">
            <div class="flex items-center">
              <%= inline_svg_tag "users.svg", class: "w-5 block stroke-1.5 stroke-black-300" %>
              <span class="block ml-2 mr-4 text-lg">Passengers</span>
            </div>
            <div class="flex items-center gap-x-8">
              <button class="">
                <%= inline_svg_tag "minus.svg", class: "w-4 block stroke-[1px] stroke-black-300" %>
              </button>
              <span class="block text-lg">1</span>
              <button class="">
                <%= inline_svg_tag "plus.svg", class: "w-5 h-5 block stroke-[1.6px] stroke-black-300" %>
              </button>
            </div>
          </div>
        </div>
        <div class="w-1/7">
          <button class="bg-blue text-white font-medium mr-3 py-4 block px-10 text-lg rounded-full cursor-pointer ml-auto">
            Search rides
          </button>
        </div>
      </div>
    </div> 
  </section>  

    <div id="leaving-from-popover" data-popover-target="popover" class="hidden tooltip bg-white border border-gray-200 rounded-b-2xl shadow-sm">
      <h2 data-location-filters-target="leavingFromHint" class="px-5 pt-4 pb-4 mb-3 font-medium text-[15px] text-black-300 bg-gray-100"></h2>
      <div class="search-results divide-y divide-gray-200"></div>
    </div> 


    <div id="going-to-popover" data-popover-target="popover" class="hidden tooltip bg-white border border-gray-200 rounded-2xl shadow-sm">
      <h2 data-location-filters-target="goingToHint" class="px-5 pt-4 pb-2 font-medium text-[14px] text-black-600"></h2>
      <div class="search-results divide-y divide-gray-200"></div>
    </div> 
  <% end %>
</div>


<div class="flex items-center gap-x-12 mt-16">
  <div class="w-1/2 relative rounded-2xl overflow-hidden lg:aspect-628/342 lg:h-full! h-85.5!">
    <%= image_tag "roadside.jpg", class: "w-full object-cover lg:group-hover:scale-110 transition-transform duration-700 ease-in-out" %>
    <div class="absolute inset-0 opacity-50 bg-linear-to-b from-transparent to-[rgba(0,0,0,1)] group-hover:opacity-100 transition-opacity duration-700 ease-in-out"></div>
    <div class="absolute bottom-0 left-0 right-0 flex flex-col px-8 py-6 text-white gap-6">
      <div class="text-white font-bold text-3xl -mt-4">
        <span class="block">Hitchhiking is hard. </span>
        <span class="block -mt-1">Make it easier. </span>
      </div>
      <div class="mt-0 w-1/2 text-sm tracking-wide lg:block max-h-0 max-w-93.75 group-hover:max-h-16.5 group-hover:opacity-100 transition-all duration-700 ease-in-out">
        <p>Make hitchhiking more predictable. Know your ride before you start your journey.</p>
      </div>
      <button class="block bg-white w-fit mt-12 text-slate-800 rounded-full px-6 py-3 font-medium">For Passengers</button>
    </div>
  </div>

  <div class="w-1/2 relative rounded-2xl overflow-hidden lg:aspect-628/342 lg:h-full! h-85.5!">
    <%= image_tag "driver_hero_2.jpg", class: "w-full object-cover lg:group-hover:scale-110 transition-transform duration-700 ease-in-out" %>
    <div class="absolute inset-0 opacity-50 bg-linear-to-b from-transparent to-[rgba(0,0,0,0.05)] group-hover:opacity-100 transition-opacity duration-700 ease-in-out"></div>
    <div class="absolute bottom-0 left-0 right-0 flex flex-col px-8 py-6 text-white gap-6">
      <div class="text-white font-bold text-3xl -mt-4">
        <span class="block">Empty seats are costly. </span>
        <span class="block -mt-1">Share and save. </span>
      </div>
      <div class="mt-0 w-1/2 text-sm tracking-wide lg:block max-h-0 max-w-93.75 group-hover:max-h-16.5 group-hover:opacity-100 transition-all duration-700 ease-in-out">
        <p>Share your ride and reduce your fuel and tollgate costs on the highyway.</p>
      </div>
      <button class="block bg-white w-fit mt-12 text-slate-800 rounded-full px-6 py-3 font-medium">For Drivers</button>
    </div>
  </div>
</div>

  
<section class="">
  <h1 class="hidden font-extrabold text-4xl tracking-tight">Some people get there. Others arrive.</h1>


<section class="">
  <h2 class="mt-24 font-extrabold text-5xl tracking-tight">Find your perfect ride</h2>

  <div class="flex flex-col gap-6 mt-8">
    <div class="flex items-start gap-x-16">
      <div class="w-1/3">
        <%= inline_svg_tag "clock.svg", class: "w-7 h-7 stroke-gray-400 stroke-[1.5]" %>
        <h3 class="font-bold text-xl mt-3">Travel on time</h3>
        <p class="text-gray-500 text-base mt-2">Choose rides with clear departure times and plan your journey with confidence.</p>
      </div>

      <div class="w-1/3">
        <%= inline_svg_tag "coins.svg", class: "w-7 h-7 stroke-gray-400 stroke-[1.5] fill-none" %>
        <h3 class="font-bold text-xl mt-3">Your pick of rides at low prices</h3>
        <p class="text-gray-500 text-base mt-2">
          No matter where you’re going, find the perfect ride from our growing network of drivers and routes at low prices.
        </p>
      </div>

      <div class="w-1/3">
        <%= inline_svg_tag "shield_v2.svg", class: "w-7 h-7 stroke-gray-400 stroke-[1.5] fill-none" %>
        <h3 class="font-bold text-xl mt-3">Trust who you travel with</h3>
        <p class="text-gray-500 text-base mt-2">
          We take the time to get to know each of our users. We check profiles, so you can book your ride at ease on our secure platform.
        </p>
      </div>
    </div>
    <div class="flex items-start gap-x-16">
      <div class="w-1/3">
        <%= inline_svg_tag "lady.svg", class: "w-7 h-8 stroke-gray-400 stroke-24 -mt-[2px]" %>
        <h3 class="font-bold text-xl mt-3">Women-only trips </h3>
        <p class="text-gray-500 text-base mt-2">Women drivers. Women passengers. For safety and comfort.</p>
      </div>

      <div class="w-1/3">
        <%= inline_svg_tag "route.svg", class: "w-6 h-6 stroke-gray-400 stroke-[1.5]" %>
        <h3 class="font-bold text-xl mt-3">Popular routes</h3>
        <p class="text-gray-500 text-base mt-2">Choose from routes people travel every day and find a ride going your way.</p>
      </div>

      <div class="w-1/3">
        <%= inline_svg_tag "music_note.svg", class: "w-6 h-6 stroke-gray-400 stroke-[1.5]" %>
