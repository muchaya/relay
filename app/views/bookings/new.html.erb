      
<h2 class="text-4xl font-extrabold my-12 text-center">Reserve your seat (Pay $0.50 now)</h2>

<section class="flex items-start gap-x-12 mx-auto w-4/5">
  <div class="w-1/2">
    <div>
      <h2 class="text-lg font-medium text-black-700 mb-2">Reservation fee</h2>
      <h2 class="text-3xl font-bold">US $0.50</h2>
    </div>

    <div class="flex items-center gap-x-4 my-12">
      <div class="border border-blue-500 rounded-md w-fit">
        <%= image_tag @trip.driver.avatar, class: "h-[64px] w-[64px] object-cover rounded-md border-[3] border-white block" %>
      </div>
      <div class="">
        <h2 class="text-2xl font-bold">Ride with <%= @trip.driver.fullname %></h2>
        <h3 class="text-black-600 text-sm">Trip from Harare to Mutare<%=  %></h3>
      </div>
    </div>

    <div class="flex items-center justify-between gap-x-12 py-3 border-t border-b border-gray-200">
      <div class="flex items-center gap-x-2">
        <%= inline_svg_tag "calendar.svg", class: "w-5 h-[17px] stroke-black fill-none  stroke-2"%>
        <p><%= @trip.departs_on %></p>
      </div>

      <div class="flex items-center gap-x-2">
        <%= inline_svg_tag "clock.svg", class: "w-4 h-[18px] stroke-black stroke-[2.5]"%>
        <p class="ml-1"><%= @trip.departs_at %></p>
        <%= inline_svg_tag "arrow.svg", class: "stroke-gray-300 stroke-black fill-gray-500 w-6 h-3" %>
        <p class=""><%= @trip.arrives_at %></p>
      </div> 
    </div>

    <div class="flex items-center gap-x-3 stroke-2 py-3 border-b border-gray-200">
      <%= inline_svg_tag "users.svg", class: "w-5 h-5 stroke-black stroke-1"%>
      <p>2 seats left</p>
    </div>

    <div class="mt-8">
      <h2 class="text-lg font-bold mb-2">Plans changed?</h2>

      <p class="text-[14px] text-gray-500">
        You can cancel anytime before the trip.
        The reservation fee isn’t refunded, it confirms your commitment.
      </p>
    </div>
  </div>

  <div class="w-1/2 rounded-lg mx-12">
    <div class="flex flex-col gap-x-6 rounded-2xl ">
      <h2 class="font-bold text-xl mb-3">Select payment method</h2>

      <div data-controller="radio-accordion" data-action="click->radio-accordion#toggle" class="flex flex-col border border-gray-300 rounded-2xl bg-white">
        <label class="text-lg border-b rounded-t-lg border-gray-200 py-3 px-5 w-full cursor-pointer">
          <div class="flex items-center justify-between gap-x-2">
            <div class="flex items-center gap-x-5">
              <%= inline_svg_tag "payment_logos/card.svg", class: "w-5 h-5 stroke-1" %>
              <div class="flex flex-col">
                <span class="block text-[15px]">Visa or Mastercard</span>
                <div class="flex items-center gap-x-0.5 -mt-1">
                  <%= inline_svg_tag "payment_logos/visa.svg", class: "w-6 h-5 stroke-[1.5]" %>
                  <%= inline_svg_tag "payment_logos/mastercard.svg", class: "w-6 h-4 stroke-[1.5]" %>
                </div>
              </div>
            </div>

            <div class="flex items-center group">
              <input type="radio" data-radio-accordion-target="trigger" name="payment_method" value="vmc" class="hidden peer" style="display: none !important;">
              <span class="flex items-center justify-center w-5 h-5 rounded-full border-2 border-gray-200 group-has-checked:border-black-200 bg-white ">
                <span class="block w-3 h-3 rounded-full bg-white group-has-checked:bg-black-200 group-has-checked:border-black-200"></span>
              </span>
            </div>
          </div>
          <ol data-radio-accordion-target="content" class="hidden py-2 text-sm text-black-500 list-outside list-decimal px-6">
            <li class="my-2">We'll redirect you to Paynow to authorize your card for this first payment only.</li>
            <li>Once finished, your card will be securely linked for one-click payments next time.</li>
          </ol>
        </label>

        <label class="text-lg border-b rounded-t-lg border-gray-200 py-5 px-5 w-full cursor-pointer">
          <div class="flex items-center justify-between gap-x-2">
            <div class="flex items-center gap-x-5">
              <%= image_tag "payment_logos/zimswitch.png", class: "-ml-1 w-6.5 h-5 object-cover" %>
              <div class="flex flex-col">
                <span class="block text-[15px] -ml-0.5">Zimswitch</span>
              </div>
            </div>

            <div class="flex items-center group">
              <input type="radio" data-radio-accordion-target="trigger" name="payment_method" value="zimswitch" class="hidden peer" style="display: none !important;">
              <span class="flex items-center justify-center w-5 h-5 rounded-full border-2 border-gray-200 group-has-checked:border-black-200 bg-white">
                <span class="block w-3 h-3 rounded-full bg-white group-has-checked:bg-black-200 group-has-checked:border-black-200"></span>
              </span>
            </div>
          </div>
          <ol data-radio-accordion-target="content" class="hidden py-2 text-sm text-black-500 list-outside list-decimal px-6">
            <li class="my-2">We'll redirect you to Paynow to authorize your card for this first payment only.</li>
            <li>Once finished, your card will be securely linked for one-click payments next time.</li>
          </ol>
        </label>

        <label class="text-lg border-b rounded-t-lg border-gray-200 py-3 px-5 w-full cursor-pointer">
          <div class="flex items-center justify-between gap-x-2">
            <div class="flex items-center gap-x-5">
              <%= image_tag "payment_logos/mobile_money.png", class: "w-5 h-5" %>
              <div class="flex flex-col">
                <span class="block text-[15px]">Ecocash or OneMoney</span>
                <div class="flex items-center gap-x-2">
                  <%= image_tag "payment_logos/ecocash.png", class: "w-6 h-4  object-cover" %>
                  <%= image_tag "payment_logos/onemoney.jpg", class: "w-6 h-4  object-cover" %>
                </div>
              </div>
            </div>

            <div class="flex items-center group">
              <input type="radio" data-radio-accordion-target="trigger" name="payment_method" value="card" class="hidden peer" style="display: none !important;">
              <span class="flex items-center justify-center w-5 h-5 rounded-full border-2 border-gray-200 group-has-checked:border-black-200 bg-white">
                <span class="block w-3 h-3 rounded-full bg-white group-has-checked:bg-black-200 group-has-checked:border-black-200"></span>
              </span>
            </div>
          </div>
          <div data-radio-accordion-target="content" class="hidden p-6 bg-gray-50 rounded-md mt-3">
            <div class="space-y-2">
              <label for="phone" class="block text-sm font-medium text-black-200">Enter your Ecocash or OneMoney number</label>
              <input type="tel"  id="phone" placeholder="0771 111 111" class="bg-white placeholder:tracking-widest w-full px-3 py-2.5 text-base border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500/50 focus:ring-offset-1 focus:border-gray-300 hover:border-gray-300 transition-all">
            </div>
          </div>
        </label>

        <label class="text-lg border-b rounded-t-lg border-gray-200 py-5 px-5 w-full cursor-pointer">
          <div class="flex items-center justify-between gap-x-2">
            <div class="flex items-center gap-x-4">
              <%= inline_svg_tag "payment_logos/omari.svg", class: "w-6 h-4" %>
              <div class="flex flex-col">
                <span class="block text-[15px]">O'mari</span>
              </div>
            </div>

            <div class="flex items-center group">
              <input type="radio" data-radio-accordion-target="trigger" name="payment_method" value="card" class="hidden peer" style="display: none !important;">
              <span class="flex items-center justify-center w-5 h-5 rounded-full border-2 border-gray-200 group-has-checked:border-black-200 bg-white ">
                <span class="block w-3 h-3 rounded-full bg-white group-has-checked:bg-black-200 group-has-checked:border-black-200"></span>
              </span>
            </div>
          </div>
          <div data-radio-accordion-target="content" class="hidden px-1 py-2">
            <h2 class="text-gray-500 text-sm mt-3 mb-2">Card information</h2>
          </div>
        </label>

        <label class="text-lg rounded-t-lg border-gray-200 py-5 px-5 w-full cursor-pointer">
          <div class="flex items-center justify-between gap-x-2">
            <div class="flex items-center gap-x-4">
            <%= inline_svg_tag "payment_logos/innbucks.svg", class: "w-6 h-4" %>
              <div class="flex flex-col">
                <span class="block text-[15px]">Innbucks</span>
              </div>
            </div>

            <div class="flex items-center group">
              <input type="radio" data-radio-accordion-target="trigger" name="payment_method" value="card" class="hidden peer" style="display: none !important;">
              <span class="flex items-center justify-center w-5 h-5 rounded-full border-2 border-gray-200 group-has-checked:border-black-200 bg-white ">
                <span class="block w-3 h-3 rounded-full bg-white group-has-checked:bg-black-200 group-has-checked:border-black-200"></span>
              </span>
            </div>
          </div>
          <div data-radio-accordion-target="content" class="hidden px-1 py-2">
            <h2 class="text-gray-500 text-sm mt-3 mb-2">Card information</h2>
          </div>
        </label>
      </div>

      <div class="my-8">
        <p class="block text-[13px] text-black-500 font-400 text-justify">
          By confirming, you authorize Relay to charge you according to its terms.
        </p> 
        <button class="bg-blue-400 text-white/40 text-base py-4 text-center w-full mt-8 my-4 rounded-full">Confirm and Pay</button>
      </div>        
    </div> 
  </div>
</section>