<h2 class="text-4xl font-extrabold my-12 text-center">
  Secure your <%= "seat".pluralize(@seats) %> for $<%= formatted_price(@trip.commitment_fee_for @seats) %>
</h2>

<section class="flex items-start gap-x-12 mx-auto w-4/5">
  <div class="w-1/2">
    <div>
      <h2 class="text-xl font-medium text-black-700 mb-2">Booking fee</h2>
      <div class="flex items-baseline gap-x-1">
        <h2 class="text-4xl font-bold">US $0.50</h2>
        <p class="font-medium text-black-700">per seat</p>
      </div>  
    </div>

    <div class="flex items-center gap-x-4 my-12">
      <div class="border border-blue-500 rounded-md w-fit">
        <%= image_tag @trip.driver.avatar, class: "h-[64px] w-[64px] object-cover rounded-md border-[3] border-white block" %>
      </div>
      <div class="">
        <h2 class="text-2xl font-bold">Ride with <%= @trip.driver.fullname %></h2>
        <h3 class="text-black-600 text-sm">Trip from Harare to Mutare<%=  %></h3>
      </div>
    </div>

    <div class="flex items-center justify-between gap-x-12 py-3 border-t border-b border-gray-200">
      <div class="flex items-center gap-x-2">
        <%= inline_svg_tag "calendar.svg", class: "w-5 h-[17px] stroke-black fill-none  stroke-2"%>
        <p><%= @trip.departs_on %></p>
      </div>

      <div class="flex items-center gap-x-2">
        <%= inline_svg_tag "clock.svg", class: "w-4 h-[18px] stroke-black stroke-[2.5]"%>
        <p class="ml-1"><%= @trip.departs_at %></p>
        <%= inline_svg_tag "arrow.svg", class: "stroke-gray-300 stroke-black fill-gray-500 w-6 h-3" %>
        <p class=""><%= @trip.arrives_at %></p>
      </div> 
    </div>

    <div class="flex items-center gap-x-3 stroke-2 py-3 border-b border-gray-200">
      <%= inline_svg_tag "users.svg", class: "w-5 h-5 stroke-black stroke-1"%>
      <p><%= pluralize(@trip.available_seats, 'seat') %> left</p>
    </div>

    <div class="mt-8">
      <h2 class="text-lg font-bold mb-2">Plans changed?</h2>

      <p class="text-[14px] text-gray-500">
        You can cancel anytime before the trip. <br>
        This $<%= formatted_price(@trip.commitment_fee_for @seats)%> secures your seats instantly. It’s non-refundable.
      </p>
    </div>
  </div>
  
  <%= form_with model: Booking.new, 
                id: "payment-form",
                data: { controller: "segmented-controls" }, 
                class: "rounded-3xl w-1/2" do |form| %>

    <%= form.hidden_field :seats, value: @seats %>
    <%= form.hidden_field :commitment_fee, value: 1 %>
    <%= form.hidden_field :trip_id, value: @trip.id %>
    <%= form.hidden_field :passenger_id, value: User.first.id %>
      
    <div data-controller="radio-cards">
      <div class="p-2 bg-blue/10 rounded-4xl">
        <div class=" bg-white py-3 px-4 rounded-t-4xl border-b border-gray-200">
          <%= segmented_controls_for(["Pay with Mobile Money", "Pay by Card"]) %>
        </div>

        <div class="flex flex-col divide-y divide-gray-200 grid-rows-4 rounded-b-2xl bg-white ">
          <% ["ecocash", "onemoney", "innbucks", "omari"].each_with_index do |method, i| %>
            <label class="cursor-pointer">
              <%= form.radio_button :payment_method, method, 
                    class: "hidden! peer group bg-white",
                    checked: (i == 0),
                    data: { 
                      radio_cards_target: "radio", 
                      action: "change->radio-cards#select" 
                    } 
                %>

              <div class="group flex items-center justify-between py-4 px-6 transition-all duration-150">
                <div class="flex items-center gap-x-3 tracking-wide peer-checked:border-0 ">
                  <% if method == "ecocash" %>
                    <div class="flex items-center justify-center-safe border border-blue/20 px-2 h-8 rounded-md">
                      <%= inline_svg_tag "payment_logos/ecocash.svg", class: "w-12 h-16" %>
                    </div>
                    
                    <span class="text-lg text-slate-600">Ecocash</span>

                  <% elsif method == "onemoney" %>
                    <div class="flex items-center justify-center-safe border border-blue/20 px-2 h-8 rounded-md">
                      <%= image_tag "payment_logos/onemoney.jpg", class: "w-12 h-6 object-cover" %>
                    </div>

                    <span class="text-lg text-slate-600">OneMoney</span>

                  <% elsif method == "innbucks" %>
                    <div class="flex items-center justify-center-safe border border-blue/20 px-2 h-8 rounded-md">
                      <%= image_tag "payment_logos/innbucks.svg", class: "w-12 h-4 object-fit" %>
                    </div>

                    <span class="text-lg text-slate-600">Innbucks</span>

                  <% elsif method == "omari" %>
                    <div class="flex items-center justify-center-safe border border-blue/20 px-2 h-8 rounded-md">
                      <%= inline_svg_tag "payment_logos/omari.svg", class: "w-12 h-6" %>
                    </div>

                    <span class="text-lg text-slate-600">Omari</span>
                  <% end %>
                </div>
                <div class="w-8 h-8 rounded-full bg-blue hidden group-peer-checked:flex items-center justify-between">
                  <%= inline_svg_tag "tick.svg", class: "w-5 h-5 stroke-white stroke-1 fill-white block mx-auto" %>
                </div>
              </div>
            </label>
          <% end %>
        </div>     

        <%# Content panels — one per method %>
        <% ["ecocash", "onemoney", "innbucks", "omari"].each do |method| %>
          <div data-radio-cards-target="content" data-method="<%= method %>" class="hidden mt-2">
            <div class="bg-white rounded-t-2xl px-4 py-3">
              <label class="block text-base text-gray-500 mb-2">Enter your <%= method.capitalize%> number</label>
              <%= form.telephone_field :phone_number, placeholder: "0781 222 000", class: "w-full border border-gray-300 rounded-lg px-3 py-4 text-base focus:outline-none focus:border-gray-200 focus:shadow-[0_0_0_1px_rgba(50,151,211,0.5),0_1px_1px_0_rgba(0,0,0,0.07),0_0_0_4px_rgba(50,151,211,0.5),0_0_0px_1000px_#fff_inset]" %>
            </div>
          </div>  
        <% end %> 

        <div class="bg-white rounded-b-4xl py-3 px-4">
          <button class="px-4 bg-blue text-white text-lg py-3.5 text-center w-full mb-2 rounded-full">
            Book your <%= "seat".pluralize(@seats) %> for $<%= formatted_price(@trip.commitment_fee_for @seats) %>
          </button>
          <p class="block text-[12px] text-black-700 text-center font-400">
            By confirming, you authorize Relay to charge you according to its terms.
          </p> 
        </div>
      </div>
    </div>
  <% end %>
</section>
