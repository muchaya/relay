<div class="w-1/2 mx-auto">
  <h2 class="text-3xl text-center font-medium">Relay</h2>

  <div class="mt-24 w-fit mx-auto">
    <%= image_tag "on_the_road.jpg", class: "w-84" %>
  </div>  

  <h1 class="text-3xl font-extrabold text-slate-800 mt-6 text-center">Booked! See you on the road.</h1>

  <button class="mt-12 w-fit mx-auto block px-12 bg-black text-white text-lg py-3 text-center mb-2 rounded-full">
    See driver details and instructions
  </button>
  <p class="text-gray-700 text-sm text-center">You'll be riding with <%= trip.driver.fullname %></p>
</div>  
